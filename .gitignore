# ==========================================
# 1. 依赖与编译产物 (Dependencies & Build)
# ==========================================
node_modules/
.next/
out/
build/
dist/

# ==========================================
# 2. 数据库与本地持久化 (Database)
# ==========================================
# 必须忽略，防止泄露反馈数据，同时也避免 Git 追踪二进制文件的频繁变化
feedbacks.db
feedbacks.db-journal

# ==========================================
# 3. 环境与敏感信息 (Environment & Secrets)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================================
# 4. AI 模型与大型二进制文件 (AI & Binary Files)
# ==========================================
# 你的 U-Net/DeepLabV3+ 权重文件体积很大，不建议存入 Git
*.pth
*.onnx
*.weights
*.bin

# 软件安装包/执行文件
*.exe
*.msi
*.zip

# ==========================================
# 5. 系统与编辑器缓存 (OS & Editors)
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.log

# ==========================================
# 6. 其他 (Misc)
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*